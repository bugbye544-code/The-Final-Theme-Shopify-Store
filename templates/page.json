span><span class=\"sep\"> <\/span>\n            <span class=\"mm\">00<\/span><span class=\"sep\"> <\/span>\n            <span class=\"ss\">00<\/span>\n          <\/span>\n        <\/div>\n\n        <div class=\"ny-special__pillrow\">\n          <div class=\"risk\">Sell-Out Risk: <b>High<\/b><\/div>\n          <span class=\"divider\"><\/span>\n          <div class=\"free\"><b>FREE<\/b> shipping<\/div>\n        <\/div>\n\n        <p class=\"ny-special__guarantee\">\n          Try it today with a 180-Day Money Back<br>\n          Guarantee!\n        <\/p>\n      <\/div>\n    <\/div>\n  <\/div>\n<\/section>\n\n<script>\n  (function () {\n    \/\/ Countdown: 10h -> 0, persistent per visitor via localStorage\n    const KEY = \"ny_special_timer_end_v1\";\n    const DURATION_MS = 10 * 60 * 60 * 1000; \/\/ 10 hours\n    const now = Date.now();\n\n    let end = Number(localStorage.getItem(KEY));\n    if (!end || isNaN(end) || end < now - 24*60*60*1000) {\n      \/\/ (Re)start if missing or very old\n      end = now + DURATION_MS;\n      localStorage.setItem(KEY, String(end));\n    }\n\n    const root = document.querySelector(\"[data-ny-timer]\");\n    if (!root) return;\n\n    const hh = root.querySelector(\".hh\");\n    const mm = root.querySelector(\".mm\");\n    const ss = root.querySelector(\".ss\");\n\n    function pad2(n){ return String(n).padStart(2,\"0\"); }\n\n    function tick(){\n      const t = Math.max(0, end - Date.now());\n      const totalSec = Math.floor(t \/ 1000);\n      const H = Math.floor(totalSec \/ 3600);\n      const M = Math.floor((totalSec % 3600) \/ 60);\n      const S = totalSec % 60;\n\n      hh.textContent = pad2(H);\n      mm.textContent = pad2(M);\n      ss.textContent = pad2(S);\n\n      if (t <= 0) {\n        \/\/ stop at 00 00 00\n        clearInterval(intv);\n      }\n    }\n\n    tick();\n    const intv = setInterval(tick, 1000);\n  })();\n<\/script>","color_scheme":"background-1","padding_top":40,"padding_bottom":52}}},"order":["main","c