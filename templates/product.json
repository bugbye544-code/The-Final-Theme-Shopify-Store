          }
        },
        "template--21507361800487__8beb6911-28c6-482c-976a-e5421ad3e8df-icon_with_text-3": {
          "type": "icon_with_text",
          "settings": {
            "column": "col_4",
            "visibility": "always-display",
            "icon": "water_drop",
            "filled_icon": false,
            "icon_size": "m",
            "icon_position": "next-to-title",
            "icon_color": "accent-1",
            "icon_heading_size": "h3",
            "icon_text_alignment": "left",
            "title": "Skincare that finally sinks in",
            "text": "<p>The gentle warmth helps your serum or eye cream absorb better, so the products you’re already using can actually do more.</p>",
            "margin_top": 20,
            "margin_bottom": 30
          }
        },
        "template--21507361800487__8beb6911-28c6-482c-976a-e5421ad3e8df-icon_with_text-4": {
