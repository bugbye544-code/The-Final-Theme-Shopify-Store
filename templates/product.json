    "8beb6911-28c6-482c-976a-e5421ad3e8df": {
      "type": "custom-columns",
      "blocks": {
        "template--21507361800487__8beb6911-28c6-482c-976a-e5421ad3e8df-heading-1": {
          "type": "heading",
          "settings": {
            "column": "col_1",
            "visibility": "always-display",
            "heading": "What <strong>Three Minutes a Day</strong> Can Actually Change",
            "title_highlight_color": "#6d388b",
            "heading_size": "h1",
            "alignment": "center",
            "mobile_alignment": "mobile-center",
            "margin_top": 20,
            "margin_bottom": 20
          }
        },
        "template--21507361800487__8beb6911-28c6-482c-976a-e5421ad3e8df-icon_with_text-1": {
          "type": "icon_with_text",
          "settings": {
            "column": "col_2",
            "visibility": "always-display",
            "icon": "bedtime",
            "filled_icon": false,
            "icon_size": "m",
            "icon_position": "next-to-title",
            "icon_color": "accent-1",
            "icon_heading_size": "h3",
            "icon_text_alignment": "left",
            "title": "Wake up looking like you slept",
            "text": "<p>The look of morning puffiness and under-eye fatigue softens with regular use — so your first mirror check of the day feels less like a bad surprise.</p>",
            "margin_top": 20,
            "margin_bottom": 30
          }
        },
        "template--21507361800487__8beb6911-28c6-482c-976a-e5421ad3e8df-icon_with_text-2": {
          "type": "icon_with_text",
          "settings": {
            "column": "col_2",
            "visibility": "always-display",
            "icon": "spa",
            "filled_icon": false,
            "icon_size": "m",
            "icon_position": "next-to-title",
            "icon_color": "accent-1",
            "icon_heading_size": "h3",
            "icon_text_alignment": "left",
            "title": "A calmer complexion, even on unpredictable weeks",
            "text": "<p>Helps reduce the appearance of blemishes and redness, gently, without the sting or dryness that comes with harsher spot treatments.</p>",
            "margin_top": 20,
            "margin_bottom": 20
          }
        },
        "glowty_benefit_3": {
          "type": "icon_with_text",
          "settings": {
            "column": "col_2",
            "visibility": "always-display",
            "icon": "face",
            "filled_icon": false,
            "icon_size": "m",
            "icon_position": "next-to-title",
            "icon_color": "accent-1",
            "icon_heading_size": "h3",
            "icon_text_alignment": "left",
            "title": "Less concealer, more actual skin",
            "text": "<p>As your complexion looks more refreshed and even, you’ll likely reach for less coverage — not because you have to hide less, but because there’s less to hide.</p>",
            "margin_top": 20,
            "margin_bottom": 30
          }
        },
