    "55bd100e-3bbd-426c-a5cf-eed7b2a3706f": {
      "type": "testimonials",
      "blocks": {
        "template--21507361800487__55bd100e-3bbd-426c-a5cf-eed7b2a3706f-column-1": {
          "type": "column",
          "settings": {
            "star_rating": 5,
            "title": "My concealer routine got so much shorter",
            "text": "<p>“I work early shifts and my under-eyes always give it away. I’ve been using Glowty before I do my makeup and honestly my concealer routine got so much shorter — I’m not layering three products just to look awake anymore.”</p>",
            "author": "<strong>Priya M.</strong>, verified buyer"
          }
        },
        "template--21507361800487__55bd100e-3bbd-426c-a5cf-eed7b2a3706f-column-2": {
          "type": "column",
          "settings": {
            "star_rating": 5,
            "title": "The first thing that’s felt gentle and done something",
            "text": "<p>“I have the kind of skin that breaks out the week before anything important, like clockwork. I was nervous to try another device because creams always leave me red for days. This didn’t — it’s the first thing that’s felt gentle <em>and</em> done something.”</p>",
            "author": "<strong>Alexis R.</strong>, verified buyer"
          }
        },
        "template--21507361800487__55bd100e-3bbd-426c-a5cf-eed7b2a3706f-column-3": {
          "type": "column",
          "settings": {
            "star_rating": 5,
            "title": "It fits my life instead of asking me to change it",
            "text": "<p>“I’m a new mom running on maybe five hours of sleep most nights, so ‘puffy’ is basically my default face. Three minutes is genuinely all I have some mornings, so this actually fits my life instead of asking me to change it.”</p>",
            "author": "<strong>Dana K.</strong>, verified buyer"
          }
        }
      },
      "block_order": [
        "template--21507361800487__55bd100e-3bbd-426c-a5cf-eed7b2a3706f-column-1",
        "template--21507361800487__55bd100e-3bbd-426c-a5cf-eed7b2a3706f-column-2",
